# rosu-web environment variables — names only. Real values go in Vercel
# (Project → Settings → Environment Variables). Copy to .env.local for local dev.

# Database (Neon Postgres — pooled connection string)
DATABASE_URL=

# Google Drive (reuse the desktop app's OAuth client; mint a refresh token once
# by consenting as rosu.app@gmail.com — see scripts/mint-drive-token.mjs)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_DRIVE_ROOT_FOLDER=Rosu Reports

# Cloudflare Turnstile (web-form captcha)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Desktop shared friction token (must equal rosu/report.py REPORT_TOKEN)
REPORT_APP_TOKEN=

# Admin viewer
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Security
IP_HASH_SALT=
CRON_SECRET=
