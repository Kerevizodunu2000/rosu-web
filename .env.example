# rosu-web environment variables — names only, NO real values here.
# Set the real values in Vercel (Project → Settings → Environment Variables).
# Copy to .env.local for local dev (that file is gitignored).

# --- Database (pick ONE, per HANDOFF.md §5) ---
# Neon (Postgres):
DATABASE_URL=
# or Turso (SQLite):
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=

# --- Image / blob storage (pick per HANDOFF.md §5) ---
# Vercel Blob:
# BLOB_READ_WRITE_TOKEN=
# or Cloudinary:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Spam protection ---
# Cloudflare Turnstile (web form captcha):
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# Shared friction token for the DESKTOP app path (must match rosu/report.py REPORT_TOKEN):
# REPORT_APP_TOKEN=

# --- Optional admin viewer (/admin) ---
# ADMIN_PASSWORD=
